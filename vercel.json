{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/drive-sync",
      "schedule": "0 3 * * *"
    }
  ]
}
