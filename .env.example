# Database
DATABASE_URL=postgres://user:pass@host:5432/crelab

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_API_KEY=ba_your-api-key-here

# Supabase (for RLS)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Google OAuth (Better Auth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Google Drive / APIs
GOOGLE_API_KEY=your-google-api-key

# Public app URL (used for sitemap/robots)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mock data mode — set to "true" to enable mock data when DB is unavailable
NEXT_PUBLIC_MOCK_DATA=true
